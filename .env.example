# ─────────────────────────────────────────────
# Redis (mesmo do Driver — referenciar no Railway)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# Email
# ─────────────────────────────────────────────
EMAIL_PROVIDER=brevo        # brevo | resend | smtp

# ── Brevo (recomendado — gratuito, sem domínio, HTTP API) ──────────────
# 1. Crie conta em brevo.com
# 2. Verifique seu e-mail remetente em Settings → Senders & IPs → Senders
# 3. Gere a API Key em Settings → API Keys
# SMTP não é necessário — o Brevo usa HTTP API (funciona no Railway free)
BREVO_API_KEY=xkeysib-xxxxxxxxxxxx
BREVO_FROM=seuapp@gmail.com
BREVO_FROM_NAME=Driver App

# ── Resend (requer domínio verificado para envio em produção) ──────────
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM=noreply@seudominio.com

# ── SMTP — Gmail (bloqueado no Railway free plan) ──────────────────────
# Portas 25, 465, 587 e 2525 são bloqueadas no Railway Hobby/Free.
# Use apenas para desenvolvimento local.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seuapp@gmail.com
# SMTP_PASS=xxxxxxxxxxxxxxxxxxxx
# SMTP_FROM=seuapp@gmail.com

# ─────────────────────────────────────────────
# Links (para construir URLs nos e-mails)
# ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001

# ─────────────────────────────────────────────
# HTTP + WebSocket (porta única — Railway injeta PORT automaticamente)
# ─────────────────────────────────────────────
PORT=3002
ADMIN_API_KEY=troque-por-chave-segura-gerada-com-openssl

# Heartbeat WebSocket (opcional)
WS_HEARTBEAT_INTERVAL_MS=30000
