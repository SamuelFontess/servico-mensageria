# ─────────────────────────────────────────────
# Redis (mesmo do Driver — referenciar no Railway)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# Email
# ─────────────────────────────────────────────
EMAIL_PROVIDER=resend        # ou smtp

# Resend (recomendado)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=noreply@seudominio.com

# SMTP — Gmail gratuito (sem domínio próprio)
# 1. Ative 2FA em myaccount.google.com
# 2. Crie uma senha de app em myaccount.google.com/apppasswords
# 3. Use a senha gerada abaixo (sem espaços)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seuapp@gmail.com
# SMTP_PASS=xxxxxxxxxxxxxxxxxxxx
# SMTP_FROM=seuapp@gmail.com

# ─────────────────────────────────────────────
# Links (para construir URLs nos e-mails)
# ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001

# ─────────────────────────────────────────────
# HTTP + WebSocket (porta única — Railway injeta PORT automaticamente)
# ─────────────────────────────────────────────
PORT=3002
ADMIN_API_KEY=troque-por-chave-segura-gerada-com-openssl

# Heartbeat WebSocket (opcional)
WS_HEARTBEAT_INTERVAL_MS=30000
